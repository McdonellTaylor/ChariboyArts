@model IEnumerable<CHARIBOY_ARTS.Areas.Admin.Models.Videos>

<h2>Videos</h2>

<div class="container">
    <div class="row pt-4">
        <div class="col-6">
            <h2 class="text-primary">Videos</h2>
        </div>
        <div class="col-6 text-end">
            <a asp-area="Admin" asp-controller="Video" asp-action="CreateVideo" class="btn btn-primary">
                Upload A Video
            </a>
        </div>
    </div>
    <table class="table">
        <thead>
            <tr>
                <th>Title</th>
                <th>Description</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var video in Model)
            {
                <tr>
                    <td>@video.Title</td>
                    <td>@video.Description</td>
                   
                    <td> <a asp-controller="Video" asp-action="" asp-route-id="@video.Id" class="btn btn-primary">Details</a></td>
                    <td> <a asp-controller="Video" asp-action="DeleteVideo" asp-route-id="@video.Id" class="btn btn-primary">Delete</a></td>
                </tr>
            }
        </tbody>
    </table>
</div>
