@model Product

<div>
    <div class="row">
        <div class="col-10">
            <form method="post" enctype="multipart/form-data">
                <input asp-for="@Model.Id" hidden />
                <input asp-for="@Model.ImageUrl" hidden />
                <div class="border p-3 mt-4">
                    <div>
                        <h2 class="text-secondary text-danger">Delete Drawing</h2>
                        <hr />
                    </div>
                    <div asp-validation-summary="All"></div>
                    <div class="mb-3">
                        <label asp-for="@Model.Name"></label>
                        <input asp-for="@Model.Name" type="text" class="form-control" disabled />
                        
                    </div>
                    <div class="mb-3">
                        <label asp-for="@Model.Title"></label>
                        <input asp-for="@Model.Title" type="text" class="form-control" disabled />
                        
                    </div>
                    <div class="mb-3">
                        <label asp-for="@Model.Category"></label>
                        <input asp-for="@Model.Category" type="text" class="form-control" disabled />
                        
                    </div>
                    <div class="mb-3">
                        <label asp-for="@Model.Price"></label>
                        <input asp-for="@Model.Price" type="text" class="form-control" disabled />
                        
                    </div>
                    <div class="mb-3">
                        <label asp-for="@Model.Description"></label>
                        <textarea asp-for="@Model.Description" type="text" class="form-control" disabled></textarea>
                        
                    </div>
                    <div class="mb-3">
                        <label asp-for="@Model.ImageUrl"></label>
                        <input asp-for="@Model.ImageUrl" type="file" name="file" class="form-control" disabled />
                        
                    </div>
                    <div class="mb-3">
                        <label asp-for="@Model.PriceDiscount"></label>
                        <input asp-for="@Model.PriceDiscount" type="text" class="form-control" disabled />
                        
                    </div>

                    <button type="submit" class="btn btn-primary text-bg-danger">Delete</button>
                    <a asp-area="Admin" asp-controller="Product" asp-action="Index" class="btn btn-secondary">Back</a>
                </div>
                <div class="col-2">
                    <img src="@Model.ImageUrl" width="100" />
                </div>
            </form>
        </div>

    </div>
</div>